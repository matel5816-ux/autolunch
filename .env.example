# ========================
# LINE Bot Configuration
# ========================
LINE_CHANNEL_SECRET=YOUR_CHANNEL_SECRET_HERE
LINE_CHANNEL_ACCESS_TOKEN=YOUR_CHANNEL_ACCESS_TOKEN_HERE

# LINE Bot 回調 URL
# 部署後填入：https://your-domain.com/webhook/line
LINE_WEBHOOK_URL=http://localhost:5000/webhook/line

# ========================
# Google APIs Configuration
# ========================
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY_HERE

# ========================
# Company Configuration
# ========================
# 群健科技 (Cofit) 座標（已驗證）
# 地址：104臺北市中山區行政里松江路363號4樓
# Google Maps: https://maps.google.com/maps/place/Cofit+群健科技
COMPANY_LATITUDE=25.0638409
COMPANY_LONGITUDE=121.5334954
COMPANY_NAME=群健科技 Cofit

# 距離篩選選項（公尺）
# 支援的距離選項：300m, 600m, 1000m, 1500m
DISTANCE_OPTIONS=300,600,1000,1500
DEFAULT_DISTANCE=1000

# 備選公司位置（支援多點）
# COMPANY_LOCATIONS={"Main": [25.0512, 121.5368], "Branch": [25.0400, 121.5700]}

# ========================
# Database Configuration
# ========================
# SQLite（開發環境）
DATABASE_URL=sqlite:///./data/restaurants.db

# PostgreSQL（生產環境，如需更改）
# DATABASE_URL=postgresql://user:password@localhost/autolunch

# ========================
# Application Configuration
# ========================
# Flask 應用環境
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-for-session-encryption

# 日誌等級
LOG_LEVEL=DEBUG

# ========================
# Feature Flags
# ========================
# 是否啟用地理位置驗證（測試時可關閉）
ENABLE_DISTANCE_VALIDATION=True

# 是否啟用 LINE Rich Menu（進階功能）
ENABLE_RICH_MENU=False

# ========================
# Performance & Limits
# ========================
# 最大同時請求數
MAX_CONCURRENT_REQUESTS=100

# Rate Limiting（每分鐘）
RATE_LIMIT_PER_MINUTE=30

# 距離篩選預設半徑（公尺）
DEFAULT_RADIUS_METERS=1000

# ========================
# Monitoring & Analytics
# ========================
# Sentry（錯誤追蹤，選用）
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/12345

# Grafana Loki（日誌聚合，選用）
# LOKI_URL=http://localhost:3100

# ========================
# Email Configuration（選用，用於告警）
# ========================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL=admin@company.com
